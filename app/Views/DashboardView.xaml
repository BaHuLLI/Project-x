<UserControl x:Class="ProjectXProDash.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:renderers="clr-namespace:ProjectXProDash.Renderers">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <renderers:MainCanvasRenderer />

                <UniformGrid Grid.Row="1" Columns="2" Margin="0,24,0,0">
                    <Border Margin="0,0,12,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="Speed" />
                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding Speed}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="Latency" />
                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding Latency}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1" Margin="24,0,0,0">
            <Border Margin="0,0,0,24" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Game Status" />
                    <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Stage" />
                    <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding GameStatus}" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,0,24" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Device Info" />
                    <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Device" />
                    <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding DeviceName}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Bridge" />
                    <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding DeviceInfo}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Frame Clock" />
                    <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Target" />
                    <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding FrameRate}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
