                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource DataCapsuleStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="State" />
