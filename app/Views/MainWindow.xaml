                                                   FontFamily="{DynamicResource UiFontFamily}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="Ready" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,24,0,0"
                                Background="{StaticResource RightCardBrush}"
                                BorderThickness="0"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Device Info" />
                                <Border Style="{StaticResource DataCapsuleStyle}" Margin="0,14,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="Device" />
                                            <TextBlock Foreground="{StaticResource TextBrush}"
                                                       FontFamily="{DynamicResource UiFontFamily}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="Project-X Core Unit" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource RightCardSecondaryTextBrush}"
                                                   FontFamily="{DynamicResource UiFontFamily}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="Direct" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource DataCapsuleStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="Firmware" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontFamily="{DynamicResource UiFontFamily}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Text="PX-FW 0.9.31" />
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="Bridge" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontFamily="{DynamicResource UiFontFamily}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Text="USB-C Direct" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
