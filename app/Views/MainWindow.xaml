<Window x:Class="ProjectXProDash.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:ProjectXProDash.Core"
        xmlns:renderers="clr-namespace:ProjectXProDash.Renderers"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Project-X Pro Dash"
        Width="1440"
        Height="860"
        MinWidth="1000"
        MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="WindowButtonStyleLocal" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostHeaderButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryButtonBorderBrush}" />
            <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="GhostChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GhostChrome" Property="Background" Value="{StaticResource SecondaryButtonHoverBrush}" />
                                <Setter TargetName="GhostChrome" Property="BorderBrush" Value="{StaticResource SecondaryButtonBorderBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyleLocal" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="DataCapsuleStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource RightCardInnerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RightCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border x:Name="MaskBorder"
                Margin="1"
                Background="Black"
                BorderThickness="0"
                CornerRadius="11"
                IsHitTestVisible="False" />

        <Border Margin="1" Background="{StaticResource BgBrush}" BorderThickness="0" CornerRadius="11">
            <Border.OpacityMask>
                <VisualBrush Visual="{Binding ElementName=MaskBorder}" Stretch="Fill" />
            </Border.OpacityMask>

            <Grid>
                <Border BorderBrush="{StaticResource RightCardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="11"
                        IsHitTestVisible="False" />
                <Ellipse Width="312"
                         Height="188"
                         Margin="0,-42,-16,0"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.42,0.38"
                                             GradientOrigin="0.42,0.38"
                                             RadiusX="0.94"
                                             RadiusY="0.94">
                            <GradientStop Color="#24FFB347" Offset="0.0" />
                            <GradientStop Color="#10FF6A00" Offset="0.44" />
                            <GradientStop Color="#00FF6A00" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="36" />
                    </Ellipse.Effect>
                </Ellipse>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="72" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.RowSpan="2" Background="{StaticResource SidebarBaseBrush}" BorderThickness="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="72" />
                                <RowDefinition Height="56" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{StaticResource HeaderMidBrush}"
                                    BorderThickness="0"
                                    core:WindowDragBehavior.IsEnabled="True">
                                <Grid>
                                    <Viewbox Width="42" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="42" Height="26">
                                            <Path Fill="#FFFFFF" Data="M0,0 L12,0 C17,0 20,3 20,8 C20,13 17,16 12,16 L6,16 L6,26 L0,26 Z M6,5 L6,11 L11,11 C13,11 14,10 14,8 C14,6 13,5 11,5 Z" />
                                            <Path Fill="#FFFFFF" Data="M22,4 L27,0 L31,0 L27,7 L22,4 Z" />
                                            <Path Fill="#FFFFFF" Data="M22,18 L30,8 L35,8 L27,18 L22,26 L18,26 L26,15 L22,18 Z" />
                                            <Path Data="M29,0 L42,0 L33,11 L29,7 Z">
                                                <Path.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FFB347" Offset="0" />
                                                        <GradientStop Color="#FF6A00" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Path.Fill>
                                            </Path>
                                            <Path Fill="#FFFFFF" Data="M31,15 L35,19 L28,26 L22,26 Z" />
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="2" Margin="0,6,0,0">
                                <Button Command="{Binding ShowDashboardCommand}" Style="{StaticResource NavButtonStyleLocal}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Height="54">
                                                <Border x:Name="ActiveLine"
                                                        Width="4"
                                                        Margin="0"
                                                        HorizontalAlignment="Left"
                                                        Background="{StaticResource AccentBrush}"
                                                        BorderThickness="0"
                                                        Visibility="Collapsed" />
                                                <Border x:Name="HoverSurface"
                                                        Margin="12,4,12,4"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        CornerRadius="12" />
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontFamily="{DynamicResource TelemetryFontFamily}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Text="DB" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontFamily="{DynamicResource UiFontFamily}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Text="DASH" />
                                                </StackPanel>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HoverSurface" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                                            </Trigger>
                                                <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                                    <Setter TargetName="ActiveLine" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Command="{Binding ShowSettingsCommand}" Style="{StaticResource NavButtonStyleLocal}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Height="54">
                                                <Border x:Name="ActiveLine"
                                                        Width="4"
                                                        Margin="0"
                                                        HorizontalAlignment="Left"
                                                        Background="{StaticResource AccentBrush}"
                                                        BorderThickness="0"
                                                        Visibility="Collapsed" />
                                                <Border x:Name="HoverSurface"
                                                        Margin="12,4,12,4"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        CornerRadius="12" />
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontFamily="{DynamicResource TelemetryFontFamily}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Text="IO" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontFamily="{DynamicResource UiFontFamily}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Text="SET" />
                                                </StackPanel>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HoverSurface" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                                            </Trigger>
                                                <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                                    <Setter TargetName="ActiveLine" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Command="{Binding ShowThemesCommand}" Style="{StaticResource NavButtonStyleLocal}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Height="54">
                                                <Border x:Name="ActiveLine"
                                                        Width="4"
                                                        Margin="0"
                                                        HorizontalAlignment="Left"
                                                        Background="{StaticResource AccentBrush}"
                                                        BorderThickness="0"
                                                        Visibility="Collapsed" />
                                                <Border x:Name="HoverSurface"
                                                        Margin="12,4,12,4"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        CornerRadius="12" />
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontFamily="{DynamicResource TelemetryFontFamily}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Text="TH" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontFamily="{DynamicResource UiFontFamily}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Text="THE" />
                                                </StackPanel>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HoverSurface" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                                            </Trigger>
                                                <DataTrigger Binding="{Binding IsThemesActive}" Value="True">
                                                    <Setter TargetName="ActiveLine" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                            <Grid Grid.Row="3" Margin="10,0,10,14">
                                <ToggleButton x:Name="LanguageButton"
                                              Height="44"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsLanguagePopupOpen, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Grid>
                                                <Border Background="#B3181411"
                                                        BorderThickness="0"
                                                        CornerRadius="14">
                                                    <Border.Effect>
                                                        <BlurEffect Radius="10" />
                                                    </Border.Effect>
                                                </Border>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               Foreground="#FFFFFF"
                                                               FontFamily="{DynamicResource TelemetryFontFamily}"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Text="{Binding CurrentLanguage}" />
                                                    <TextBlock HorizontalAlignment="Center"
                                                               Foreground="#FFFFFF"
                                                               FontFamily="{DynamicResource UiFontFamily}"
                                                               FontSize="9"
                                                               FontWeight="SemiBold"
                                                               Text="LANG" />
                                                </StackPanel>
                                            </Grid>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup IsOpen="{Binding IsLanguagePopupOpen}"
                                       Placement="Top"
                                       PlacementTarget="{Binding ElementName=LanguageButton}"
                                       AllowsTransparency="True"
                                       StaysOpen="False">
                                    <Grid Width="{Binding ActualWidth, ElementName=LanguageButton}" Margin="0,0,0,10">
                                        <Border Background="#B3181411" BorderThickness="0" CornerRadius="12">
                                            <Border.Effect>
                                                <BlurEffect Radius="18" />
                                            </Border.Effect>
                                        </Border>
                                        <ItemsControl Margin="8" ItemsSource="{Binding Languages}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Margin="0,2,0,2"
                                                            Padding="10,8"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalContentAlignment="Center"
                                                            Command="{Binding DataContext.SelectLanguageCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="RowChrome"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        CornerRadius="8">
                                                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                      VerticalAlignment="Center" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="RowChrome" Property="Background" Value="{StaticResource Glow18Brush}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <TextBlock Foreground="#FFFFFF"
                                                                   FontFamily="{DynamicResource UiFontFamily}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding}" />
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Background="{StaticResource HeaderMidBrush}"
                            BorderThickness="0"
                            core:WindowDragBehavior.IsEnabled="True">
                        <Grid>
                            <Grid Margin="18,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Grid.ColumnSpan="2" core:WindowDragBehavior.IsEnabled="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Foreground="{StaticResource TextBrush}"
                                                   FontFamily="{DynamicResource TelemetryFontFamily}"
                                                   FontSize="20"
                                                   FontWeight="Black"
                                                   Text="PROJECT-X PRO DASH" />
                                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                            <Ellipse Width="6"
                                                     Height="6"
                                                     Margin="0,3,6,0"
                                                     Fill="{StaticResource AccentBrush}" />
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontFamily="{DynamicResource UiFontFamily}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Text="Connected, Low Latency Mode" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <Button Grid.Column="2"
                                        Height="44"
                                        MinWidth="134"
                                        Margin="0,0,14,0"
                                        Padding="0"
                                        Background="{StaticResource PreviewGradientBrush}"
                                        BorderThickness="0"
                                        Command="{Binding TogglePreviewCommand}"
                                        VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Border x:Name="PreviewSurface" Background="{TemplateBinding Background}"
                                                        BorderThickness="0"
                                                        CornerRadius="4">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="24"
                                                                          ShadowDepth="0"
                                                                          Color="{StaticResource Glow40Color}"
                                                                          Opacity="0.85" />
                                                    </Border.Effect>
                                                </Border>
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#1B120D"
                                                           FontFamily="{DynamicResource UiFontFamily}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Text="Start Preview"
                                                           TextOptions.TextFormattingMode="Display"
                                                           TextOptions.TextRenderingMode="ClearType" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="PreviewSurface" Property="Opacity" Value="0.92" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Grid.Column="3"
                                        Margin="0,0,12,0"
                                        Command="{Binding ShowThemesCommand}"
                                        Content="Browse Themes"
                                        Style="{StaticResource GhostHeaderButtonStyle}"
                                        VerticalAlignment="Center" />

                                <Button Grid.Column="4"
                                        Margin="0,0,12,0"
                                        Content="Test Device"
                                        Style="{StaticResource GhostHeaderButtonStyle}"
                                        VerticalAlignment="Center" />

                                <StackPanel Grid.Column="5"
                                            Margin="0,0,15,0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Command="{Binding MinimizeCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                            Content="_"
                                            Style="{StaticResource WindowButtonStyleLocal}" />
                                    <Button Margin="6,0,0,0"
                                            Command="{Binding MaximizeCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                            Content="&#x25A1;"
                                            Style="{StaticResource WindowButtonStyleLocal}" />
                                    <Button Margin="6,0,0,0"
                                            Command="{Binding CloseCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                            Content="&#x00D7;"
                                            Style="{StaticResource WindowButtonStyleLocal}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Margin="24,0,0,24"
                            Background="{StaticResource PanelDarkBrush}"
                            BorderThickness="0"
                            CornerRadius="14">
                        <Grid>
                            <Ellipse Width="620"
                                     Height="220"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,-106"
                                     IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.5,0.28"
                                                         GradientOrigin="0.5,0.28"
                                                         RadiusX="0.9"
                                                         RadiusY="0.9">
                                        <GradientStop Color="#47FF8A1F" Offset="0.0" />
                                        <GradientStop Color="#1FD94E00" Offset="0.45" />
                                        <GradientStop Color="#008F4E24" Offset="1.0" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <BlurEffect Radius="50" />
                                </Ellipse.Effect>
                            </Ellipse>

                            <Ellipse Width="760"
                                     Height="94"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,22"
                                     Fill="#7A050505"
                                     IsHitTestVisible="False">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="26" />
                                </Ellipse.Effect>
                            </Ellipse>

                            <Ellipse Width="520"
                                     Height="34"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,0,44"
                                     Fill="#11F3E8DC"
                                     IsHitTestVisible="False">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="16" />
                                </Ellipse.Effect>
                            </Ellipse>

                            <Ellipse Width="250"
                                     Height="174"
                                     Margin="0,-16,-18,0"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Top"
                                     IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.45,0.42"
                                                         GradientOrigin="0.45,0.42"
                                                         RadiusX="0.94"
                                                         RadiusY="0.94">
                                        <GradientStop Color="#20FFB347" Offset="0.0" />
                                        <GradientStop Color="#12FF8A1F" Offset="0.48" />
                                        <GradientStop Color="#008F4E24" Offset="1.0" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <BlurEffect Radius="28" />
                                </Ellipse.Effect>
                            </Ellipse>

                            <Grid Margin="24">
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Foreground="{StaticResource MutedBrush}"
                                               FontFamily="{DynamicResource UiFontFamily}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Text="DEVICE HERO" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="{DynamicResource TelemetryFontFamily}"
                                               FontSize="24"
                                               FontWeight="Black"
                                               Text="PROJECT-X CORE UNIT" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontFamily="{DynamicResource UiFontFamily}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="Studio-grade physical dashboard control stage" />
                                </StackPanel>

                                <renderers:MainCanvasRenderer Margin="8,92,8,28" />

                                <StackPanel Margin="0,0,0,4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom">
                                    <TextBlock Foreground="{StaticResource MutedBrush}"
                                               FontFamily="{DynamicResource UiFontFamily}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Text="Skia stage ready. Internal telemetry intentionally deferred." />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="24,24,24,24">
                        <Border Background="{StaticResource RightCardBrush}"
                                BorderThickness="0"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Game Status" />
                                <Border Style="{StaticResource DataCapsuleStyle}" Margin="0,14,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                Background="{StaticResource SurfacePanelBrush}"
                                                BorderThickness="0"
                                                CornerRadius="17">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12"
                                                                  ShadowDepth="0"
                                                                  Color="{StaticResource Glow28Color}"
                                                                  Opacity="0.7" />
                                            </Border.Effect>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource OrangeSoftBrush}"
                                                       FontFamily="{DynamicResource TelemetryFontFamily}"
                                                       FontSize="16"
                                                       FontWeight="Black"
                                                       Text="&#x25C6;" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="Provider" />
