<Window x:Class="ProjectXProDash.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:ProjectXProDash.Core"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Project-X Pro Dash"
        Width="1440"
        Height="860"
        MinWidth="1000"
        MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <RadialGradientBrush x:Key="WindowCoreGlowBrush"
                             Center="0.5,0.46"
                             GradientOrigin="0.5,0.46"
                             RadiusX="0.65"
                             RadiusY="0.65">
            <GradientStop Color="#2EFF7800" Offset="0" />
            <GradientStop Color="#18FF7800" Offset="0.28" />
            <GradientStop Color="#00FF7800" Offset="1" />
        </RadialGradientBrush>

        <DrawingBrush x:Key="WindowNoiseBrush"
                      Stretch="None"
                      TileMode="Tile"
                      Viewbox="0,0,120,120"
                      ViewboxUnits="Absolute"
                      Viewport="0,0,120,120"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFFFFFFF">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <EllipseGeometry Center="18,24" RadiusX="1" RadiusY="1" />
                                <EllipseGeometry Center="52,78" RadiusX="1" RadiusY="1" />
                                <EllipseGeometry Center="97,31" RadiusX="1" RadiusY="1" />
                                <EllipseGeometry Center="84,102" RadiusX="1" RadiusY="1" />
                                <EllipseGeometry Center="29,96" RadiusX="0.8" RadiusY="0.8" />
                                <EllipseGeometry Center="110,67" RadiusX="0.8" RadiusY="0.8" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <RadialGradientBrush x:Key="WindowVignetteBrush"
                             Center="0.5,0.5"
                             GradientOrigin="0.5,0.5"
                             RadiusX="0.88"
                             RadiusY="0.88">
            <GradientStop Color="#00000000" Offset="0.58" />
            <GradientStop Color="#22000000" Offset="0.8" />
            <GradientStop Color="#66000000" Offset="1" />
        </RadialGradientBrush>

        <SolidColorBrush x:Key="AccentBrush" Color="#FF8C00" />
        <SolidColorBrush x:Key="SidebarButtonHoverBrush" Color="#1FE62E00" />
        <SolidColorBrush x:Key="SidebarButtonActiveBrush" Color="#33E62E00" />
        <SolidColorBrush x:Key="SidebarButtonAccentBorderBrush" Color="#4DE62E00" />
        <Geometry x:Key="IconHome">F1 M 11,2 L 3,9 L 5,9 L 5,18 L 10,18 L 10,13 L 14,13 L 14,18 L 19,18 L 19,9 L 21,9 Z</Geometry>
        <Geometry x:Key="IconSettings">F1 M 11,2 L 12.5,2.8 L 14.2,2.6 L 15,4.2 L 16.8,5 L 18.4,4.8 L 19,6.5 L 20,8 L 19.2,9.5 L 19.4,11.2 L 21,12 L 20.2,13.5 L 19.4,15.2 L 17.8,15 L 16.2,15.8 L 15.5,17.5 L 14,17.2 L 12.4,18 L 11,20 L 9.6,18 L 8,17.2 L 6.5,17.5 L 5.8,15.8 L 4.2,15 L 2.6,15.2 L 1.8,13.5 L 1,12 L 2.6,11.2 L 2.8,9.5 L 2,8 L 3,6.5 L 3.6,4.8 L 5.2,5 L 7,4.2 L 7.8,2.6 L 9.5,2.8 Z M 11,8 A 3,3 0 1 1 10.99,8 Z</Geometry>
        <Geometry x:Key="IconPalette">F1 M 11,2 C 6,2 2,5.8 2,10.5 C 2,14.5 5.2,17.5 9.2,17.5 L 10.8,17.5 C 11.8,17.5 12.5,18.2 12.5,19.2 C 12.5,20.2 13.3,21 14.3,21 C 18.8,21 22,17.2 22,12.7 C 22,6.8 17.4,2 11,2 Z M 6.5,10 A 1.2,1.2 0 1 1 6.49,10 Z M 9,6.5 A 1.2,1.2 0 1 1 8.99,6.5 Z M 14,6.2 A 1.2,1.2 0 1 1 13.99,6.2 Z M 16.5,10 A 1.2,1.2 0 1 1 16.49,10 Z</Geometry>

        <Style x:Key="SidebarIconPathStyle" TargetType="Path">
            <Setter Property="Stroke" Value="#F2F2F2" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>

        <Style x:Key="WindowButtonStyleLocal" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#CC14191E" />
            <Setter Property="Foreground" Value="#B3FFFFFF" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#26FF8C00" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButtonStyleLocal"
               BasedOn="{StaticResource WindowButtonStyleLocal}"
               TargetType="Button">
            <Setter Property="FontSize" Value="10" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3B30" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyleLocal" TargetType="Button">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Margin" Value="0,0,0,28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Effect" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="10">
                            <Border.Effect>
                                <Binding Path="Effect" RelativeSource="{RelativeSource TemplatedParent}" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource RightCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="80"
                              Direction="270"
                              Opacity="1"
                              ShadowDepth="25"
                              Color="#A6000000" />
        </Border.Effect>
        <Grid ClipToBounds="True">
            <Rectangle RadiusX="12" RadiusY="12" Fill="#070A0E" />
            <Rectangle RadiusX="12" RadiusY="12" Fill="{StaticResource WindowCoreGlowBrush}" />
            <Rectangle RadiusX="12" RadiusY="12" Fill="{StaticResource WindowNoiseBrush}" Opacity="0.025" />
            <Rectangle RadiusX="12" RadiusY="12" Fill="{StaticResource WindowVignetteBrush}" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#0E1319"
                        BorderBrush="#26FF8C00"
                        BorderThickness="0,0,0,1"
                        CornerRadius="12,12,0,0"
                        core:WindowDragBehavior.IsEnabled="True">
                    <Grid>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FF8C00"
                                   FontFamily="{DynamicResource UiFontFamily}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="PROJECT-X" />

                        <StackPanel HorizontalAlignment="Right"
                                    Margin="0,6,16,6"
                                    Orientation="Horizontal">
                            <Button Command="{Binding MinimizeCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                    Content="&#xE921;"
                                    Style="{StaticResource WindowButtonStyleLocal}" />
                            <Button Margin="8,0,0,0"
                                    Command="{Binding MaximizeCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                    Content="&#xE922;"
                                    Style="{StaticResource WindowButtonStyleLocal}" />
                            <Button Margin="8,0,0,0"
                                    Command="{Binding CloseCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                    Content="&#xE8BB;"
                                    Style="{StaticResource CloseWindowButtonStyleLocal}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{StaticResource RightCardBorderBrush}"
                            BorderThickness="0,0,1,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#070C12" Offset="0" />
                                <GradientStop Color="#060A0F" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="56" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#060A0F">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextBrush}"
                                           FontFamily="{DynamicResource TelemetryFontFamily}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Text="PX" />
                            </Border>

                            <StackPanel Grid.Row="1"
                                        Margin="0,60,0,20"
                                        HorizontalAlignment="Center">
                                <Button Command="{Binding ShowDashboardCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyleLocal}">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarButtonHoverBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarButtonAccentBorderBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FF8C00"
                                                                              BlurRadius="10"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.18" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarButtonActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarButtonAccentBorderBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FF8C00"
                                                                              BlurRadius="12"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.24" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Path Data="{StaticResource IconHome}"
                                          Width="22"
                                          Height="22"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Path.Style>
                                            <Style TargetType="Path" BasedOn="{StaticResource SidebarIconPathStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                                        <Setter Property="Stroke" Value="#FFFFFF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Stroke" Value="#FFFFFF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Button>

                                <Button Command="{Binding ShowSettingsCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyleLocal}">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarButtonHoverBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarButtonAccentBorderBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FF8C00"
                                                                              BlurRadius="10"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.18" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarButtonActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarButtonAccentBorderBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FF8C00"
                                                                              BlurRadius="12"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.24" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Path Data="{StaticResource IconSettings}"
                                          Width="22"
                                          Height="22"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Path.Style>
                                            <Style TargetType="Path" BasedOn="{StaticResource SidebarIconPathStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                                        <Setter Property="Stroke" Value="#FFFFFF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Stroke" Value="#FFFFFF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Button>

                                <Button Command="{Binding ShowThemesCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyleLocal}">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarButtonHoverBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarButtonAccentBorderBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FF8C00"
                                                                              BlurRadius="10"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.18" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsThemesActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource SidebarButtonActiveBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SidebarButtonAccentBorderBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#FF8C00"
                                                                              BlurRadius="12"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.24" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Path Data="{StaticResource IconPalette}"
                                          Width="22"
                                          Height="22"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Path.Style>
                                            <Style TargetType="Path" BasedOn="{StaticResource SidebarIconPathStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsThemesActive}" Value="True">
                                                        <Setter Property="Stroke" Value="#FFFFFF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                        <Setter Property="Stroke" Value="#FFFFFF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="16"
                            Background="{StaticResource PanelMidBrush}"
                            BorderBrush="{StaticResource RightCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <ContentControl Margin="16" Content="{Binding CurrentContent}" />
                    </Border>

                    <StackPanel Grid.Column="2" Margin="0,16,16,16">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Status" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Game" />
                                <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding DashboardViewModel.GameStatus}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Device" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Name" />
                                <TextBlock Style="{StaticResource ValueTextStyle}" FontSize="18" Text="{Binding DashboardViewModel.DeviceName}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Bridge" />
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="{Binding DashboardViewModel.DeviceInfo}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Frame" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Target" />
                                <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding DashboardViewModel.FrameRate}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
