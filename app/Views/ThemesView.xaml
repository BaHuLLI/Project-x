<UserControl x:Class="ProjectXProDash.Views.ThemesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ProjectXProDash.Models">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Themes}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ThemeConfig}">
                    <Button Margin="0,0,0,18"
                            Padding="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding DataContext.SelectThemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ThemeCard"
                                        Padding="18"
                                        Background="#181D24"
                                        BorderBrush="#00000000"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="46"
                                                Height="46"
                                                Background="{Binding AccentHex}"
                                                BorderThickness="0"
                                                CornerRadius="12" />

                                        <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                            <TextBlock Foreground="#F2F4F7"
                                                       FontFamily="{DynamicResource UiFontFamily}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Text="{Binding Name}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#818896"
                                                       FontFamily="{DynamicResource UiFontFamily}"
                                                       FontSize="13"
                                                       Text="{Binding Description}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontFamily="{DynamicResource UiFontFamily}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="APPLY" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ThemeCard" Property="Background" Value="#1E242C" />
                                        <Setter TargetName="ThemeCard" Property="BorderBrush" Value="#30F09A3F" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="ThemeCard" Property="Background" Value="#24190F" />
                                        <Setter TargetName="ThemeCard" Property="BorderBrush" Value="#55F09A3F" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
