<UserControl x:Class="ProjectXProDash.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Margin="0,0,12,0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Window Memory" />
                <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Saved Bounds" />
                <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding WindowBounds}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="12,0,0,0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="External Assets" />
                <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Rajdhani-Bold.ttf" />
                <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding RajdhaniAsset}" TextWrapping="Wrap" />
                <TextBlock Margin="0,14,0,0" Style="{StaticResource LabelTextStyle}" Text="Inter-Regular.ttf" />
                <TextBlock Style="{StaticResource ValueTextStyle}" Text="{Binding InterAsset}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
