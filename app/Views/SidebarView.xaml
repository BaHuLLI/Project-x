<UserControl x:Class="ProjectXProDash.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ProjectXProDash.Views">
    <Border Background="{StaticResource PanelBrush}" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="128" />
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource MetalBrush}" BorderThickness="0">
                <Grid>
                    <Border Width="52"
                            Height="52"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{StaticResource SurfaceBrush}"
                            BorderThickness="0"
                            CornerRadius="12">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontFamily="{DynamicResource TelemetryFontFamily}"
                                       FontWeight="Black"
                                       FontSize="18"
                                       Text="PX" />
                            <TextBlock HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextBrush}"
                                       FontFamily="{DynamicResource UiFontFamily}"
                                       FontSize="8"
                                       FontWeight="SemiBold"
                                       Text="PRO" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2">
                <Button Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Command="{Binding ShowDashboardCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Height="54">
                                <Border x:Name="ActiveLine"
                                        Width="4"
                                        HorizontalAlignment="Left"
                                        Margin="0"
                                        Background="{StaticResource AccentBrush}"
                                        BorderThickness="0"
                                        CornerRadius="0,2,2,0"
                                        Visibility="Collapsed" />
                                <Border x:Name="HoverSurface"
                                        Margin="12,4,12,4"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        BorderThickness="0" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center"
                                               FontFamily="{DynamicResource TelemetryFontFamily}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"
                                               Text="DB" />
                                    <TextBlock Margin="0,4,0,0"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource LabelTextStyle}"
                                               Text="DASH" />
                                </StackPanel>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverSurface" Property="Background" Value="{StaticResource HoverBrush}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                    <Setter TargetName="ActiveLine" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="HoverSurface" Property="Background" Value="#14FF6A00" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Command="{Binding ShowSettingsCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Height="54">
                                <Border x:Name="ActiveLine"
                                        Width="4"
                                        HorizontalAlignment="Left"
                                        Margin="0"
                                        Background="{StaticResource AccentBrush}"
                                        BorderThickness="0"
                                        CornerRadius="0,2,2,0"
                                        Visibility="Collapsed" />
                                <Border x:Name="HoverSurface"
                                        Margin="12,4,12,4"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        BorderThickness="0" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center"
                                               FontFamily="{DynamicResource TelemetryFontFamily}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"
                                               Text="IO" />
                                    <TextBlock Margin="0,4,0,0"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource LabelTextStyle}"
                                               Text="SET" />
                                </StackPanel>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverSurface" Property="Background" Value="{StaticResource HoverBrush}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                    <Setter TargetName="ActiveLine" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="HoverSurface" Property="Background" Value="#14FF6A00" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Command="{Binding ShowThemesCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Height="54">
                                <Border x:Name="ActiveLine"
                                        Width="4"
                                        HorizontalAlignment="Left"
                                        Margin="0"
                                        Background="{StaticResource AccentBrush}"
                                        BorderThickness="0"
                                        CornerRadius="0,2,2,0"
                                        Visibility="Collapsed" />
                                <Border x:Name="HoverSurface"
                                        Margin="12,4,12,4"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        BorderThickness="0" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center"
                                               FontFamily="{DynamicResource TelemetryFontFamily}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"
                                               Text="TH" />
                                    <TextBlock Margin="0,4,0,0"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource LabelTextStyle}"
                                               Text="THE" />
                                </StackPanel>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverSurface" Property="Background" Value="{StaticResource HoverBrush}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsThemesActive}" Value="True">
                                    <Setter TargetName="ActiveLine" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="HoverSurface" Property="Background" Value="#14FF6A00" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <views:LangSelectorView Grid.Row="3" Margin="12,0,12,16" />
        </Grid>
    </Border>
</UserControl>
