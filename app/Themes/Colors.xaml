    <SolidColorBrush x:Key="BackgroundDeepBrush" Color="{StaticResource BackgroundDeepColor}" />
    <SolidColorBrush x:Key="BackgroundBaseBrush" Color="{StaticResource BackgroundBaseColor}" />
    <SolidColorBrush x:Key="PanelDarkBrush" Color="{StaticResource PanelDarkColor}" />
    <SolidColorBrush x:Key="PanelMidBrush" Color="{StaticResource PanelMidColor}" />
