    <SolidColorBrush x:Key="RightCardInnerBrush" Color="{StaticResource RightCardInnerColor}" />
    <SolidColorBrush x:Key="RightCardBorderBrush" Color="{StaticResource RightCardBorderColor}" />
    <SolidColorBrush x:Key="RightCardSecondaryTextBrush" Color="{StaticResource RightCardSecondaryTextColor}" />
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BackgroundBaseColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelMidColor}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource OrangeMainColor}" />
    <SolidColorBrush x:Key="CloseHoverBrush" Color="{StaticResource OrangeMainColor}" />
</ResourceDictionary>
