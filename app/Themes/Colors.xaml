    <Color x:Key="BackgroundDeepColor">#050505</Color>
    <Color x:Key="BackgroundBaseColor">#070A0E</Color>
    <Color x:Key="PanelDarkColor">#101010</Color>
    <Color x:Key="PanelMidColor">#141414</Color>
