<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BackgroundDeepColor">#070708</Color>
    <Color x:Key="BackgroundBaseColor">#0B0B0C</Color>
    <Color x:Key="PanelDarkColor">#101113</Color>
    <Color x:Key="PanelMidColor">#141518</Color>
